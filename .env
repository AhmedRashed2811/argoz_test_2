DEBUG=1
SECRET_KEY=dev-insecure-change-me
ALLOWED_HOSTS=*
TIME_ZONE=UTC

# MariaDB (docs §2.2) — only used when USE_MYSQL=1 or in production
USE_MYSQL=1
MYSQL_DATABASE=argoz
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Redis / Celery / Channels
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=0

# Email / integrations
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.prometheus.com.eg
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=system@prometheus.com.eg
